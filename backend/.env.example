PORT=4000
CORS_ORIGIN=http://localhost:5173

DATABASE_URL=postgres://waypoint:waypoint@localhost:5433/waypoint

# mock | password | okta | cloudflare-access
AUTH_MODE=mock

# Password-mode bootstrap. Required when AUTH_MODE=password. On the
# very first boot the app creates this user with the given plaintext
# password (bcrypt-hashed at rest). Idempotent thereafter — an
# existing user with a password on file is left untouched, so
# rotated credentials survive restarts.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin

# Populate these when AUTH_MODE=okta (bearer ID tokens from a browser SPA).
OKTA_ISSUER=
OKTA_AUDIENCE=
OKTA_CLIENT_ID=

# Populate these when AUTH_MODE=cloudflare-access. Cloudflare Access
# fronts the app, does the OIDC dance with the IdP, and forwards a
# signed JWT on every request; see DEPLOY.md for the full setup.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# Set to the absolute path of the built frontend to serve it from the
# same origin as the API (the Docker image sets this automatically).
# Leave blank in dev so Vite serves the SPA on :5173.
STATIC_DIR=

# Anchors the weekly-status cron. Change if your team isn't on Central Time.
REPORTING_TIMEZONE=America/Chicago
